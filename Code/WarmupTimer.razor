@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent
@namespace Sandbox

<root>
	<div class=WarmupUIPanel>
	@if ( Warm.ShowPizzaText )
	{
	    <p>Pizza Time! Take the pizza to the customer!</p>
	}
	else if ( Warm.TimeRemaining > 0 )
	{
	   <p>Placing Pizza in : @Warm.TimeRemaining</p>
	}
	</div>
</root>

@code
{
	[Property] WebSlingerWarmup Warm { get; set; }
	//<p>Pizza Time! @Warm.PizzaPlayer.GameObject.Name has been picked!</p>
	protected override int BuildHash()
	{
		return System.HashCode.Combine( Warm.TimeRemaining, Warm.PizzaPlayer, Warm.ShowPizzaText );
	}
}
